{
  "name": "interviewpilot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "AI-powered interview simulation platform powered by Cursor SDK",
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "tsx watch src/index.ts",
    "dev:web": "npm run dev --workspace=frontend",
    "build": "npm run build:api && npm run build --workspace=frontend",
    "build:api": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit && npm run typecheck --workspace=frontend"
  },
  "workspaces": [
    "frontend"
  ],
  "dependencies": {
    "@cursor/sdk": "^1.0.13",
    "@hono/node-server": "^1.14.4",
    "@supabase/supabase-js": "^2.49.8",
    "dotenv": "^16.5.0",
    "hono": "^4.12.19",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  }
}
